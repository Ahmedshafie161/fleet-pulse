"""
Shared pytest fixtures — mirrors the original project's test setup.
Uses an in-memory SQLite DB and overrides FastAPI dependencies.
"""

import builtins

import pytest
from fastapi.testclient import TestClient
from sqlalchemy import create_engine
from sqlalchemy.orm import scoped_session, sessionmaker

# ── Inject test settings before any app import ────────────────────────────────
from dynaconf import Dynaconf

builtins.settings = Dynaconf(  # type: ignore[attr-defined]
    settings_file=[],
    environments=False,
)
builtins.settings.PROJECT_NAME = "FleetPulse Test"  # type: ignore[attr-defined]
builtins.settings.SECRET_KEY = "test-secret-key"  # type: ignore[attr-defined]
builtins.settings.ACCESS_TOKEN_EXPIRE_MINUTES = 5  # type: ignore[attr-defined]
builtins.settings.DATABASE_FILE = ":memory:"  # type: ignore[attr-defined]
builtins.settings.setenv("testing") # type: ignore[attr-defined]
builtins.settings.MQTT_BROKER_HOST = "localhost"  # type: ignore[attr-defined]
builtins.settings.MQTT_BROKER_PORT = 1883  # type: ignore[attr-defined]
builtins.settings.MQTT_TELEMETRY_TOPIC = "fleet/+/telemetry"  # type: ignore[attr-defined]
builtins.settings.ASSETS_DIR = "assets"  # type: ignore[attr-defined]

# ── Now import app code ────────────────────────────────────────────────────────
from restapi.db.models.base import Base, BaseModel
from restapi.db.session import engine as _default_engine

# Replace engine with in-memory SQLite
_test_engine = create_engine("sqlite:///:memory:", connect_args={"check_same_thread": False})
Base.metadata.create_all(bind=_test_engine)

_TestSession = scoped_session(sessionmaker(bind=_test_engine))
BaseModel.set_session(_TestSession)

from restapi.server import app
from restapi.core.auth import get_password_hash
from restapi.db.models import User


@pytest.fixture(scope="function", autouse=True)
def db_session():
    """Roll back after every test."""
    connection = _test_engine.connect()
    transaction = connection.begin()
    yield connection
    transaction.rollback()
    connection.close()


@pytest.fixture
def admin_user():
    user = User.create(
        save=True,
        username="admin",
        password=get_password_hash("admin1234"),
        created_at=__import__("datetime").datetime.utcnow(),
    )
    return user


@pytest.fixture
def client(admin_user):
    with TestClient(app, raise_server_exceptions=True) as c:
        resp = c.post("/api/v1/auth/login", data={"username": "admin", "password": "admin1234"})
        token = resp.json()["access_token"]
        c.headers.update({"Authorization": f"Bearer {token}"})
        yield c
